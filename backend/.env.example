# Neon (or any PostgreSQL). Must use the asyncpg driver.
# postgresql+asyncpg://user:pass@ep-xxxxx.region.aws.neon.tech/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nexus_supply

# Auth
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default admin user created on first startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# CORS — comma separated origins (your Vercel URL in prod)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Run schema.sql + seed automatically on startup (great for demos)
AUTO_INIT_DB=true
AUTO_SEED=true
